<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NOKIA SNAKE 3310</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

        body {
            margin: 0;
            padding: 20px;
            background: #0a0a0a;
            color: #00ff00;
            font-family: 'Press Start 2P', cursive;
            text-align: center;
            image-rendering: pixelated;
        }

        h1 {
            font-size: 32px;
            margin: 10px 0 5px;
            text-shadow: 0 0 15px #00ff00;
            letter-spacing: 4px;
        }

        .container {
            display: inline-block;
            background: #111;
            padding: 20px;
            border: 10px solid #222;
            box-shadow: 0 0 30px #00ff00;
            border-radius: 8px;
        }

        canvas {
            background: #000;
            border: 6px solid #00ff00;
            image-rendering: pixelated;
            box-shadow: 0 0 20px #00ff00;
        }

        #ui {
            margin: 15px 0;
            font-size: 18px;
            display: flex;
            justify-content: space-between;
            max-width: 400px;
            margin-left: auto;
            margin-right: auto;
        }

        .info {
            background: #111;
            padding: 8px 15px;
            border: 3px solid #00ff00;
        }

        button {
            background: #000;
            color: #00ff00;
            border: 3px solid #00ff00;
            padding: 10px 20px;
            font-family: 'Press Start 2P', cursive;
            font-size: 14px;
            cursor: pointer;
            margin-top: 10px;
        }

        button:hover {
            background: #00ff00;
            color: #000;
        }

        .overlay {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(0, 0, 0, 0.9);
            padding: 30px;
            border: 5px solid #00ff00;
            display: none;
            flex-direction: column;
            align-items: center;
        }
    </style>
</head>
<body>
    <h1>NOKIA 3310</h1>
    <div class="container">
        <div id="ui">
            <div class="info">SCORE <span id="score">00000</span></div>
            <div class="info">HIGH <span id="highscore">00000</span></div>
        </div>
        
        <canvas id="canvas" width="400" height="400"></canvas>
        
        <div style="margin-top: 15px;">
            <button onclick="togglePause()">PAUSE / RESUME</button>
        </div>
    </div>

    <div id="startScreen" class="overlay" style="display: flex;">
        <h2>READY?</h2>
        <p style="margin: 20px 0; font-size: 14px;">PRESS SPACE TO START</p>
    </div>

    <div id="gameOverScreen" class="overlay">
        <h2>GAME OVER</h2>
        <p id="finalScore" style="margin: 15px 0;"></p>
        <button onclick="restartGame()">PLAY AGAIN</button>
    </div>

    <script>
        const canvas = document.getElementById("canvas");
        const ctx = canvas.getContext("2d");
        
        const GRID = 20;
        const COLS = canvas.width / GRID;
        const ROWS = canvas.height / GRID;

        let snake = [];
        let dx = GRID;
        let dy = 0;
        let food = { x: 0, y: 0 };
        let score = 0;
        let highScore = localStorage.getItem("snakeHighScore") || 0;
        let speed = 120; // milliseconds per frame
        let lastTime = 0;
        let gameState = "start"; // start, playing, paused, over
        let particles = [];

        document.getElementById("highscore").textContent = String(highScore).padStart(5, '0');

        function initGame() {
            snake = [
                {x: 8 * GRID, y: 10 * GRID},
                {x: 7 * GRID, y: 10 * GRID},
                {x: 6 * GRID, y: 10 * GRID}
            ];
            dx = GRID;
            dy = 0;
            score = 0;
            speed = 120;
            particles = [];
            updateScore();
            spawnFood();
        }

        function spawnFood() {
            do {
                food.x = Math.floor(Math.random() * COLS) * GRID;
                food.y = Math.floor(Math.random() * ROWS) * GRID;
            } while (snake.some(segment => segment.x === food.x && segment.y === food.y));
        }

        function updateScore() {
            document.getElementById("score").textContent = String(score).padStart(5, '0');
        }

        function createParticles(x, y) {
            for (let i = 0; i < 12; i++) {
                particles.push({
                    x: x + GRID/2,
                    y: y + GRID/2,
                    vx: (Math.random() - 0.5) * 6,
                    vy: (Math.random() - 0.5) * 6,
                    life: 25
                });
            }
        }

        function draw() {
            // Background
            ctx.fillStyle = "#001100";
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // Grid lines (retro feel)
            ctx.strokeStyle = "#003300";
            ctx.lineWidth = 1;
            for (let i = 0; i <= COLS; i++) {
                ctx.beginPath();
                ctx.moveTo(i * GRID, 0);
                ctx.lineTo(i * GRID, canvas.height);
                ctx.stroke();
            }
            for (let i = 0; i <= ROWS; i++) {
                ctx.beginPath();
                ctx.moveTo(0, i * GRID);
                ctx.lineTo(canvas.width, i * GRID);
                ctx.stroke();
            }

            // Draw Snake
            ctx.fillStyle = "#00ff00";
            for (let i = 0; i < snake.length; i++) {
                const segment = snake[i];
                ctx.fillRect(segment.x + 1, segment.y + 1, GRID - 2, GRID - 2);
                
                // Head highlight
                if (i === 0) {
                    ctx.fillStyle = "#88ff88";
                    ctx.fillRect(segment.x + 4, segment.y + 4, GRID - 8, GRID - 8);
                    ctx.fillStyle = "#00ff00";
                }
            }

            // Draw Food
            ctx.fillStyle = "#ff0000";
            ctx.fillRect(food.x + 3, food.y + 3, GRID - 6, GRID - 6);

            // Draw Particles
            for (let i = particles.length - 1; i >= 0; i--) {
                const p = particles[i];
                ctx.fillStyle = `rgba(0, 255, 0, ${p.life / 25})`;
                ctx.fillRect(p.x, p.y, 4, 4);
                
                p.x += p.vx;
                p.y += p.vy;
                p.life--;
                p.vx *= 0.95;
                p.vy *= 0.95;
                
                if (p.life <= 0) particles.splice(i, 1);
            }
        }

        function update() {
            if (gameState !== "playing") return;

            const head = { 
                x: snake[0].x + dx, 
                y: snake[0].y + dy 
            };

            // Wall collision
            if (head.x < 0 || head.x >= canvas.width || 
                head.y < 0 || head.y >= canvas.height) {
                gameOver();
                return;
            }

            // Self collision
            for (let segment of snake) {
                if (head.x === segment.x && head.y === segment.y) {
                    gameOver();
                    return;
                }
            }

            snake.unshift(head);

            // Eat food
            if (head.x === food.x && head.y === food.y) {
                score += 10;
                updateScore();
                createParticles(food.x, food.y);
                spawnFood();

                // Increase difficulty
                if (score % 50 === 0 && speed > 50) {
                    speed -= 10;
                }
            } else {
                snake.pop();
            }
        }

        function gameLoop(timestamp) {
            if (!lastTime) lastTime = timestamp;
            
            if (timestamp - lastTime > speed) {
                update();
                lastTime = timestamp;
            }

            draw();
            requestAnimationFrame(gameLoop);
        }

        function gameOver() {
            gameState = "over";
            if (score > highScore) {
                highScore = score;
                localStorage.setItem("snakeHighScore", highScore);
                document.getElementById("highscore").textContent = String(highScore).padStart(5, '0');
            }
            
            document.getElementById("finalScore").innerHTML = 
                `YOUR SCORE<br><span style="font-size:24px;">${score}</span>`;
            document.getElementById("gameOverScreen").style.display = "flex";
        }

        function startGame() {
            document.getElementById("startScreen").style.display = "none";
            initGame();
            gameState = "playing";
        }

        function restartGame() {
            document.getElementById("gameOverScreen").style.display = "none";
            initGame();
            gameState = "playing";
        }

        function togglePause() {
            if (gameState === "playing") {
                gameState = "paused";
            } else if (gameState === "paused") {
                gameState = "playing";
            }
        }

        // Controls
        document.addEventListener("keydown", (e) => {
            if (gameState === "over" || gameState === "start") {
                if (e.key === " ") {
                    if (gameState === "start") startGame();
                    else restartGame();
                }
                return;
            }

            if (e.key === " " && gameState !== "over") {
                togglePause();
                return;
            }

            if (gameState !== "playing") return;

            switch (e.key) {
                case "ArrowLeft":
                case "a":
                    if (dx !== GRID) { dx = -GRID; dy = 0; }
                    break;
                case "ArrowRight":
                case "d":
                    if (dx !== -GRID) { dx = GRID; dy = 0; }
                    break;
                case "ArrowUp":
                case "w":
                    if (dy !== GRID) { dx = 0; dy = -GRID; }
                    break;
                case "ArrowDown":
                case "s":
                    if (dy !== -GRID) { dx = 0; dy = GRID; }
                    break;
            }
        });

        // Start the game loop
        initGame();
        requestAnimationFrame(gameLoop);
    </script>
</body>
</html>
